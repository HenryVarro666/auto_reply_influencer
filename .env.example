# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Stage 1: Instagram fetch proxy (OPTIONAL) ------------------------------
# Leave BLANK to connect directly with your LOCAL IP (good for small tests;
# fetching all ~100 accounts on a single IP may get rate-limited).
# To use a rotating residential gateway instead, set a proxy URL. MarsProxies
# format is host:port:user:pass -> http://USER:PASS@HOST:PORT.
# Put the REAL value in .env, never here:
# IG_PROXY=http://USERNAME:PASSWORD_country-us_state-georgia@ultra.marsproxies.com:44443
IG_PROXY=

# --- Stage 2: LLM provider ---------------------------------------------------
# Provider for comment generation. One of: claude-cli (default), claude-api, gpt, gemini
LLM_PROVIDER=claude-cli

# claude-cli (default): no key needed — uses the `claude` command on PATH.
# Optional override of the binary path:
# CLAUDE_CLI_BIN=claude

# gpt (second option): needs an OpenAI key.
# OPENAI_API_KEY=

# gemini: needs a Google AI Studio key.
# GEMINI_API_KEY=

# claude-api (fallback when the CLI is unavailable): needs an Anthropic key.
# ANTHROPIC_API_KEY=

# --- instagrapi fallback (OPTIONAL) ------------------------------------------
# Only used when login-free hashtag/keyword/post search returns nothing.
# Reads only — never auto-posts. Prefer SESSIONID from a warmed account.
# INSTAGRAPI_SESSIONID=
# INSTAGRAPI_USERNAME=
# INSTAGRAPI_PASSWORD=
